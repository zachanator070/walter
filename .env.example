# AWS credentials and region
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# System prompt sent to ChatGPT on every request
SYSTEM_PROMPT=You are Walter, a helpful voice assistant. Keep responses concise and conversational.

# ALSA audio devices — run 'arecord -l' to find your mic, 'aplay -l' to find your speaker
AUDIO_INPUT_DEVICE=hw:1,0
AUDIO_OUTPUT_DEVICE=hw:0,0
SAMPLE_RATE=16000

# AWS Polly text-to-speech
POLLY_VOICE_ID=Joanna
POLLY_ENGINE=neural

# Push-to-talk input device
# Run 'ls /dev/input/by-id/' for stable names, or 'cat /proc/bus/input/devices' to identify your keyboard
PTT_INPUT_DEVICE=/dev/input/event0
# Key to hold while speaking — see supported values in src/pipeline/inputDevice.js
PTT_KEY=KEY_SPACE

# How long (ms) of silence before the conversation history is reset
CONVERSATION_TIMEOUT_MS=300000

# Max number of back-and-forth turns to keep in ChatGPT context (controls token cost)
MAX_HISTORY_TURNS=20

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
