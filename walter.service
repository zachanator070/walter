[Unit]
Description=Walter voice assistant
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=pi
Group=pi
SupplementaryGroups=audio input
WorkingDirectory=/opt/walter
EnvironmentFile=/opt/walter/.env
ExecStart=/usr/bin/node --max-old-space-size=256 src/index.js
Restart=on-failure
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=15
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target